{
  "name": "frag-demo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"PORT=5050 AUTO_OPEN_BROWSER=0 bun --watch server/index.ts\" \"bunx --bun vite --host 127.0.0.1 --port 5000 --strictPort\"",
    "build:client": "bunx --bun vite build",
    "start": "bun run build:client && bun server/index.ts",
    "typecheck": "bunx --bun tsc --noEmit",
    "test": "bunx --bun vitest run"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.1.0",
    "chokidar": "^4.0.3",
    "elysia": "^1.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "bun-types": "^1.3.4",
    "concurrently": "^9.1.2",
    "jsdom": "^26.1.0",
    "vite": "^7.1.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
